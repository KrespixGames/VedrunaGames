<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>MEGAPIPER</title>
    <style>
        body { margin: 0; overflow: hidden; background: #111; font-family: Arial; }
        canvas { display: block; }
        #ui { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; }
        .hud { display: flex; justify-content: space-between; padding: 15px; }
        .stat-box { width: 280px; }
        .label { color: white; font-weight: bold; font-size: 14px; margin-bottom: 3px; display: flex; justify-content: space-between; }
        .bar-bg { background: rgba(255,255,255,0.2); border: 2px solid white; height: 22px; position: relative; }
        .bar { height: 100%; width: 100%; transition: width 0.1s; }
        #p1-hp { background: #00aaff; }
        #p2-hp { background: #ff3333; }
        .ammo-box { display: flex; gap: 4px; margin-top: 5px; }
        .ammo-pip { width: 30%; height: 18px; background: #ffff00; border-radius: 2px; transition: 0.2s; }
        .ammo-pip.empty { background: #333; opacity: 0.3; }
        .reload-msg { color: #ff0000; font-size: 11px; display: none; }
        .reload-msg.on { display: block; animation: bl 0.5s infinite; }
        @keyframes bl { 50% { opacity: 0; } }
        #msg { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); text-align: center; color: white; display: none; background: rgba(0,0,0,0.9); padding: 30px; border: 2px solid gold; border-radius: 10px; pointer-events: auto; }
        #msg h1 { color: gold; margin: 0 0 15px; }
        #msg button { font-size: 18px; padding: 8px 20px; cursor: pointer; }
        #info { position: absolute; bottom: 10px; width: 100%; text-align: center; color: #777; font-size: 13px; }
    </style>
</head>
<body>
    <div id="ui">
        <div class="hud">
            <div class="stat-box">
                <div class="label"><span>P1 (Space+Arrows)</span><span id="p1-rel" class="reload-msg">RELOADING...</span></div>
                <div class="bar-bg"><div id="p1-hp" class="bar"></div></div>
                <div class="ammo-box">
                    <div id="p1-a1" class="ammo-pip"></div>
                    <div id="p1-a2" class="ammo-pip"></div>
                    <div id="p1-a3" class="ammo-pip"></div>
                </div>
            </div>
            <div class="stat-box" style="text-align:right;">
                <div class="label"><span id="p2-rel" class="reload-msg">RELOADING...</span><span>P2 (W+A+D)</span></div>
                <div class="bar-bg"><div id="p2-hp" class="bar"></div></div>
                <div class="ammo-box">
                    <div id="p2-a1" class="ammo-pip"></div>
                    <div id="p2-a2" class="ammo-pip"></div>
                    <div id="p2-a3" class="ammo-pip"></div>
                </div>
            </div>
        </div>
        <div id="msg">
            <h1 id="win-txt">WINNER!</h1>
            <button onclick="resetGame()">PLAY AGAIN</button>
        </div>
        <div id="info">P1: Arrows to move, Space to shoot | P2: A+D to move, W to shoot</div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script>
        const MAX_HP = 200;
        const MAX_AMMO = 3;
        const RELOAD_TIME = 2000;
        const MOVE_SPEED = 0.3;
        const BULLET_SPEED = 0.8;
        const LIMIT_X = 14;

        let scene, camera, renderer;
        let player1, player2;
        let bullets = [];
        let gameActive = true;

        let hp1 = MAX_HP, hp2 = MAX_HP;
        let ammo1 = MAX_AMMO, ammo2 = MAX_AMMO;
        let reloading1 = false, reloading2 = false;

        const keys = { p1Left: false, p1Right: false, p1Shoot: false, p2Left: false, p2Right: false, p2Shoot: false };

        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x202030);
            scene.fog = new THREE.Fog(0x202030, 20, 50);

            camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 15, 25);
            camera.lookAt(0, 0, 0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            scene.add(new THREE.AmbientLight(0x404040));
            let dirLight = new THREE.DirectionalLight(0xffffff, 0.8);
            dirLight.position.set(10, 20, 10);
            dirLight.castShadow = true;
            scene.add(dirLight);

            scene.add(new THREE.GridHelper(50, 50, 0x444444, 0x222222));
            let plane = new THREE.Mesh(
                new THREE.PlaneGeometry(50, 50),
                new THREE.MeshPhongMaterial({ color: 0x111111 })
            );
            plane.rotation.x = -Math.PI / 2;
            plane.position.y = -0.1;
            scene.add(plane);

            player1 = new THREE.Mesh(
                new THREE.BoxGeometry(2, 3, 2),
                new THREE.MeshPhongMaterial({ color: 0x00aaff, emissive: 0x002244 })
            );
            player1.position.set(0, 1.5, -10);
            player1.castShadow = true;
            scene.add(player1);

            player2 = new THREE.Mesh(
                new THREE.BoxGeometry(2, 3, 2),
                new THREE.MeshPhongMaterial({ color: 0xff3333, emissive: 0x440000 })
            );
            player2.position.set(0, 1.5, 10);
            player2.rotation.y = Math.PI;
            player2.castShadow = true;
            scene.add(player2);

            window.addEventListener('resize', onResize);
            document.addEventListener('keydown', onKeyDown);
            document.addEventListener('keyup', onKeyUp);

            updateAmmoDisplay();
            updateHealthBars();
            animate();
        }

        function createBullet(x, z, direction) {
            let bullet = new THREE.Mesh(
                new THREE.SphereGeometry(0.8, 16, 16),
                new THREE.MeshBasicMaterial({ color: 0xffff00 })
            );
            bullet.position.set(x, 1.5, z);
            bullet.userData = { direction: direction };
            scene.add(bullet);
            bullets.push(bullet);
        }

        function onKeyDown(event) {
            switch(event.code) {
                case 'ArrowLeft': keys.p1Left = true; break;
                case 'ArrowRight': keys.p1Right = true; break;
                case 'Space': 
                    if (!keys.p1Shoot) shoot(1);
                    keys.p1Shoot = true; 
                    break;
                case 'KeyA': keys.p2Left = true; break;
                case 'KeyD': keys.p2Right = true; break;
                case 'KeyW': 
                    if (!keys.p2Shoot) shoot(2);
                    keys.p2Shoot = true; 
                    break;
            }
        }

        function onKeyUp(event) {
            switch(event.code) {
                case 'ArrowLeft': keys.p1Left = false; break;
                case 'ArrowRight': keys.p1Right = false; break;
                case 'Space': keys.p1Shoot = false; break;
                case 'KeyA': keys.p2Left = false; break;
                case 'KeyD': keys.p2Right = false; break;
                case 'KeyW': keys.p2Shoot = false; break;
            }
        }

        function shoot(playerNum) {
            if (!gameActive) return;
            
            if (playerNum === 1 && hp1 > 0) {
                if (ammo1 > 0 && !reloading1) {
                    createBullet(player1.position.x, player1.position.z + 1, 1);
                    ammo1--;
                    updateAmmoDisplay();
                    checkReload(1);
                }
            } else if (playerNum === 2 && hp2 > 0) {
                if (ammo2 > 0 && !reloading2) {
                    createBullet(player2.position.x, player2.position.z - 1, -1);
                    ammo2--;
                    updateAmmoDisplay();
                    checkReload(2);
                }
            }
        }

        function checkReload(playerNum) {
            if (playerNum === 1 && ammo1 === 0 && !reloading1) {
                reloading1 = true;
                document.getElementById('p1-rel').classList.add('on');
                for (let i = 1; i <= 3; i++) {
                    document.getElementById('p1-a' + i).classList.add('empty');
                }
                setTimeout(() => {
                    ammo1 = MAX_AMMO;
                    reloading1 = false;
                    document.getElementById('p1-rel').classList.remove('on');
                    updateAmmoDisplay();
                }, RELOAD_TIME);
            } else if (playerNum === 2 && ammo2 === 0 && !reloading2) {
                reloading2 = true;
                document.getElementById('p2-rel').classList.add('on');
                for (let i = 1; i <= 3; i++) {
                    document.getElementById('p2-a' + i).classList.add('empty');
                }
                setTimeout(() => {
                    ammo2 = MAX_AMMO;
                    reloading2 = false;
                    document.getElementById('p2-rel').classList.remove('on');
                    updateAmmoDisplay();
                }, RELOAD_TIME);
            }
        }

        function updateAmmoDisplay() {
            for (let i = 1; i <= 3; i++) {
                let pip1 = document.getElementById('p1-a' + i);
                let pip2 = document.getElementById('p2-a' + i);
                
                if (i > ammo1) pip1.classList.add('empty');
                else pip1.classList.remove('empty');
                
                if (i > ammo2) pip2.classList.add('empty');
                else pip2.classList.remove('empty');
            }
        }

        function updateHealthBars() {
            document.getElementById('p1-hp').style.width = (hp1 / MAX_HP * 100) + '%';
            document.getElementById('p2-hp').style.width = (hp2 / MAX_HP * 100) + '%';
        }

        function checkGameOver() {
            if (hp1 <= 0 || hp2 <= 0) {
                gameActive = false;
                let msgBox = document.getElementById('msg');
                let winText = document.getElementById('win-txt');
                
                if (hp2 <= 0) {
                    winText.textContent = 'PLAYER 1 WINS!';
                    winText.style.color = '#00aaff';
                } else {
                    winText.textContent = 'PLAYER 2 WINS!';
                    winText.style.color = '#ff3333';
                }
                
                msgBox.style.display = 'block';
            }
        }

        function resetGame() {
            hp1 = hp2 = MAX_HP;
            ammo1 = ammo2 = MAX_AMMO;
            reloading1 = reloading2 = false;
            gameActive = true;
            
            player1.position.set(0, 1.5, -10);
            player2.position.set(0, 1.5, 10);
            
            for (let b of bullets) {
                scene.remove(b);
            }
            bullets = [];
            
            document.getElementById('msg').style.display = 'none';
            updateAmmoDisplay();
            updateHealthBars();
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }

        function animate() {
            requestAnimationFrame(animate);
            
            if (gameActive) {
                if (keys.p1Left && player1.position.x > -LIMIT_X) player1.position.x -= MOVE_SPEED;
                if (keys.p1Right && player1.position.x < LIMIT_X) player1.position.x += MOVE_SPEED;
                
                if (keys.p2Left && player2.position.x > -LIMIT_X) player2.position.x -= MOVE_SPEED;
                if (keys.p2Right && player2.position.x < LIMIT_X) player2.position.x += MOVE_SPEED;
            }
            
            for (let i = bullets.length - 1; i >= 0; i--) {
                let b = bullets[i];
                b.position.z += b.userData.direction * BULLET_SPEED;
                
                let hit = false;
                
                if (b.userData.direction > 0) {
                    if (b.position.z >= player2.position.z - 1.5 && b.position.z <= player2.position.z + 1.5) {
                        if (Math.abs(b.position.x - player2.position.x) < 2) {
                            hit = true;
                            hp2 -= 20;
                            updateHealthBars();
                            checkGameOver();
                        }
                    }
                } else {
                    if (b.position.z <= player1.position.z + 1.5 && b.position.z >= player1.position.z - 1.5) {
                        if (Math.abs(b.position.x - player1.position.x) < 2) {
                            hit = true;
                            hp1 -= 20;
                            updateHealthBars();
                            checkGameOver();
                        }
                    }
                }
                
                if (hit || b.position.z < -20 || b.position.z > 20) {
                    scene.remove(b);
                    bullets.splice(i, 1);
                }
            }
            
            renderer.render(scene, camera);
        }

        init();
    </script>
</body>
</html>
