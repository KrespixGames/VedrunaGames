  <style>
    /* Artistic Flair theme configuration & Retro CRT monitor visual emulation */
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap');

    :root {
      --bg: #0c0c0e;
      --panel: #151619;
      --accent: #f27d26;
      --p1: #3b82f6;
      --p2: #22c55e;
      --treasure: #fbbf24;
      --trap: #ef4444;
      --monster: #a855f7;
      --wall: #2a2a32;
      --floor: #16161d;
      --f-mono: 'Courier New', Courier, monospace;
    }

    body {
      background-color: var(--bg);
      background-image: radial-gradient(circle at center, #1b1c22 0%, #0c0c0e 100%);
      color: #edeaf5;
      font-family: var(--f-mono);
      overflow-x: hidden;
      image-rendering: pixelated;
    }

    .retro-font-headline {
      font-family: 'Press Start 2P', monospace;
    }

    /* Scanlines and flicker simulation overlay */
    .crt-monitor {
      position: relative;
      overflow: hidden;
      border: 15px solid var(--panel);
      border-radius: 12px;
      box-shadow:
        0 0 0 3px #23242c,
        0 20px 50px rgba(0, 0, 0, 0.85),
        inset 0 0 40px rgba(0, 0, 0, 0.95);
      background-color: var(--bg);
    }

    .crt-monitor::after {
      content: " ";
      display: block;
      position: absolute;
      top: 0; left: 0; bottom: 0; right: 0;
      background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
      background-size: 100% 4px, 6px 100%;
      pointer-events: none;
      z-index: 10;
    }

    /* Screen curvature and vignette shadow */
    .screen-glare {
      pointer-events: none;
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: radial-gradient(circle at 50% 15%, rgba(255, 255, 255, 0.08) 0%, rgba(0, 0, 0, 0.5) 100%);
      z-index: 5;
    }

    /* Glow details themed dynamically */
    .glow-blue {
      text-shadow: 0 0 8px rgba(59, 130, 246, 0.85);
    }
    .glow-green {
      text-shadow: 0 0 8px rgba(34, 197, 94, 0.85);
    }
    .glow-gold {
      text-shadow: 0 0 10px rgba(242, 125, 38, 0.9);
    }
    .glow-red {
      text-shadow: 0 0 8px rgba(239, 68, 68, 0.85);
    }

    /* Custom scrollbars matching Artistic Flair theme */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #0c0c0e;
    }
    ::-webkit-scrollbar-thumb {
      background: #2a2a32;
      border-radius: 3px;
    }
    ::-webkit-scrollbar-thumb:hover {
      background: var(--accent);
    }

    /* CRT glass convex bending */
    .crt-glass {
      animation: crt-flicker 0.15s infinite alternate;
    }

    @keyframes crt-flicker {
      0% { opacity: 0.995; }
      100% { opacity: 1; }
    }

    /* Retro floating status tags */
    .stat-badge {
      border: 1px solid #31313a;
      background: rgba(21, 22, 25, 0.9);
    }

    /* Theme specific buttons from Design Specs */
    .artistic-btn {
      padding: 10px 20px;
      font-family: var(--f-mono);
      background: transparent;
      border: 2px solid var(--accent);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 2px;
      cursor: pointer;
      font-weight: bold;
      border-radius: 4px;
      transition: all 0.25s ease-in-out;
    }
    .artistic-btn:hover {
      background: var(--accent);
      color: #0c0c0e;
      box-shadow: 0 0 15px rgba(242, 125, 38, 0.4);
    }
  </style>
