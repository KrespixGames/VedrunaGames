  <!-- CORE GAME SCRIPT BLOCK -->
  <script>
    /**
     * ==========================================
     * CLASS SOUND MANAGER (Retro Synth Web Audio API)
     * ==========================================
     */
    class SoundManager {
      constructor() {
        this.ctx = null;
        this.unlocked = false;
        this.muted = false;
      }

      init() {
        if (this.unlocked) return;
        try {
          window.AudioContext = window.AudioContext || window.webkitAudioContext;
          this.ctx = new AudioContext();
          this.unlocked = true;
          console.log("Web Audio Context successfully initialized!");
        } catch (e) {
          console.warn("Web Audio API is not supported in this environment.", e);
        }
      }

      // 1. General Button Click
      playClick() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.type = 'triangle';
        o.frequency.setValueAtTime(150, ctx.currentTime);
        o.frequency.exponentialRampToValueAtTime(320, ctx.currentTime + 0.12);
       
        g.gain.setValueAtTime(0.12, ctx.currentTime);
        g.gain.linearRampToValueAtTime(0.01, ctx.currentTime + 0.12);
       
        o.connect(g);
        g.connect(ctx.destination);
        o.start();
        o.stop(ctx.currentTime + 0.12);
      }

      // 2. Dual-pickup coin sparkle chime
      playTreasure() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;

        const pulse = (freq, delay, dur) => {
          const o = ctx.createOscillator();
          const g = ctx.createGain();
          o.type = 'sine';
          o.frequency.setValueAtTime(freq, now + delay);
          o.frequency.exponentialRampToValueAtTime(freq * 1.5, now + delay + dur);

          g.gain.setValueAtTime(0.0, now);
          g.gain.linearRampToValueAtTime(0.08, now + delay + 0.01);
          g.gain.linearRampToValueAtTime(0.01, now + delay + dur);

          o.connect(g);
          g.connect(ctx.destination);
          o.start(now + delay);
          o.stop(now + delay + dur);
        };

        pulse(523.25, 0, 0.15); // C5
        pulse(659.25, 0.08, 0.18); // E5
        pulse(1046.5, 0.16, 0.25); // C6
      }

      // 3. Harsh noise/buzz trap sound
      playTrap() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;
        const dur = 0.35;

        // Draw custom noise buffer
        const bufferSize = ctx.sampleRate * dur;
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }

        const noise = ctx.createBufferSource();
        noise.buffer = buffer;

        const filter = ctx.createBiquadFilter();
        filter.type = 'lowpass';
        filter.frequency.setValueAtTime(1000, now);
        filter.frequency.exponentialRampToValueAtTime(220, now + dur);

        const g = ctx.createGain();
        g.gain.setValueAtTime(0.25, now);
        g.gain.linearRampToValueAtTime(0.01, now + dur);

        noise.connect(filter);
        filter.connect(g);
        g.connect(ctx.destination);

        noise.start(now);
        noise.stop(now + dur);
      }

      // 4. Whoosh melee attack sound
      playAttack() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;
        const dur = 0.18;

        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.type = 'triangle';
        o.frequency.setValueAtTime(510, now);
        o.frequency.exponentialRampToValueAtTime(80, now + dur);

        g.gain.setValueAtTime(0.2, now);
        g.gain.linearRampToValueAtTime(0.01, now + dur);

        o.connect(g);
        g.connect(ctx.destination);

        o.start(now);
        o.stop(now + dur);
      }

      // 5. Hard monster/player hit splat
      playHit() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;
       
        const o1 = ctx.createOscillator();
        const g1 = ctx.createGain();
        o1.type = 'sawtooth';
        o1.frequency.setValueAtTime(180, now);
        o1.frequency.linearRampToValueAtTime(60, now + 0.15);

        g1.gain.setValueAtTime(0.18, now);
        g1.gain.linearRampToValueAtTime(0.01, now + 0.15);

        o1.connect(g1);
        g1.connect(ctx.destination);
        o1.start(now);
        o1.stop(now + 0.15);
      }

      // 6. Retro collapse/death crash
      playMonsterDeath() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;
        const dur = 0.45;

        // Draw low noisy explosion
        const bufferSize = ctx.sampleRate * dur;
        const buffer = ctx.createBuffer(1, bufferSize, ctx.sampleRate);
        const data = buffer.getChannelData(0);
        for (let i = 0; i < bufferSize; i++) {
          data[i] = Math.random() * 2 - 1;
        }

        const noise = ctx.createBufferSource();
        noise.buffer = buffer;

        const filter = ctx.createBiquadFilter();
        filter.type = 'bandpass';
        filter.frequency.setValueAtTime(300, now);
        filter.frequency.exponentialRampToValueAtTime(60, now + dur);

        const g = ctx.createGain();
        g.gain.setValueAtTime(0.3, now);
        g.gain.linearRampToValueAtTime(0.01, now + dur);

        noise.connect(filter);
        filter.connect(g);
        g.connect(ctx.destination);

        noise.start(now);
        noise.stop(now + dur);
      }

      // 7. Victory level finished chime
      playVictory() {
        if (!this.unlocked || this.muted) return;
        const ctx = this.ctx;
        const now = ctx.currentTime;

        const playNote = (freq, start, duration) => {
          const o = ctx.createOscillator();
          const g = ctx.createGain();
          o.type = 'square';
          o.frequency.setValueAtTime(freq, now + start);

          g.gain.setValueAtTime(0.0, now);
          g.gain.linearRampToValueAtTime(0.08, now + start + 0.01);
          g.gain.linearRampToValueAtTime(0.06, now + start + duration - 0.02);
          g.gain.linearRampToValueAtTime(0.001, now + start + duration);

          o.connect(g);
          g.connect(ctx.destination);
          o.start(now + start);
          o.stop(now + start + duration);
        };

        const notes = [261.63, 329.63, 392.00, 523.25, 659.25, 783.99, 1046.50]; // C Major Arpeggio
        notes.forEach((freq, index) => {
          playNote(freq, index * 0.1, 0.4);
        });
      }
    }

    const soundManager = new SoundManager();


    /**
     * ==========================================
     * CLASS PARTICLE
     * ==========================================
     */
    class Particle {
      constructor(x, y, color, type = 'dust') {
        this.x = x;
        this.y = y;
        this.color = color;
        this.type = type; // 'dust', 'sparkle', 'blood', 'slash'
       
        this.vx = (Math.random() - 0.5) * 3;
        this.vy = (Math.random() - 0.5) * 3;
       
        if (type === 'blood') {
          this.vx = (Math.random() - 0.5) * 4;
          this.vy = (Math.random() - 0.6) * 5 - 2; // sprayed up slightly
        } else if (type === 'sparkle') {
          this.vx = (Math.random() - 0.5) * 1.5;
          this.vy = -Math.random() * 2 - 0.5; // floats up
        }

        this.size = Math.random() * 3.5 + 1.5;
        this.life = 1.0;
        this.decay = Math.random() * 0.04 + 0.02;
      }

      update(gravityEnabled = false) {
        this.x += this.vx;
        this.y += this.vy;
        if (gravityEnabled) {
          this.vy += 0.2; // fall slowly
        }
        this.life -= this.decay;
      }

      draw(ctx) {
        ctx.save();
        ctx.globalAlpha = Math.max(0, this.life);
        ctx.fillStyle = this.color;
       
        if (this.type === 'sparkle') {
          // Draw diamond like gem sparkle
          ctx.beginPath();
          ctx.moveTo(this.x, this.y - this.size);
          ctx.lineTo(this.x + this.size, this.y);
          ctx.lineTo(this.x, this.y + this.size);
          ctx.lineTo(this.x - this.size, this.y);
          ctx.closePath();
          ctx.fill();
        } else {
          // Draw round pixels
          ctx.fillRect(this.x - this.size/2, this.y - this.size/2, this.size, this.size);
        }
        ctx.restore();
      }
    }


