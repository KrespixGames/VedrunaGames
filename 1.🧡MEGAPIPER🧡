<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>MEGAPIPER</title>

<style>
body {
    margin:0;
    overflow:hidden;
    background:#111;
    font-family:Arial;
}

/* ===== MENU ===== */
#menu, #difficultyMenu {
    position:absolute;
    inset:0;
    background:rgba(0,0,0,0.95);
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    gap:15px;
    color:white;
    z-index:10;
}

#menu h1 {
    color:gold;
    font-size:60px;
    text-shadow:0 0 20px gold;
}
#menu{
background:linear-gradient(135deg,#0f172a,#111,#3b0764);
}
#difficultyMenu{
background:linear-gradient(135deg,#111,#220022);
}

button {
    padding:12px 25px;
    font-size:18px;
    border:none;
    border-radius:8px;
    cursor:pointer;
    transition:0.2s;
}

button:hover { transform:scale(1.05); }

#menu button:nth-child(2){ background:#00aaff; color:white; }
#menu button:nth-child(3){ background:#ff4444; color:white; }

#difficultyMenu button:nth-child(2){background:#2ecc71;}
#difficultyMenu button:nth-child(3){background:#f1c40f;}
#difficultyMenu button:nth-child(4){background:#e74c3c;}

/* ===== HUD ===== */
#ui {
    position:absolute;
    top:0;
    width:100%;
    height:100%;
    pointer-events:none;
}

.hud {
    display:flex;
    justify-content:space-between;
    padding:15px;
}

.stat-box { width:280px; }

.label {
    color:white;
    font-weight:bold;
    font-size:14px;
    display:flex;
    justify-content:space-between;
}

.bar-bg {
    background:rgba(255,255,255,0.2);
    border:2px solid white;
    height:22px;
}

.bar {
    height:100%;
    transition:0.1s;
}

#p1-hp {background:#00aaff;}
#p2-hp {background:#ff3333;}

.ammo-box {
    display:flex;
    gap:4px;
    margin-top:5px;
}

.ammo-pip {
    width:30%;
    height:18px;
    background:#ffff00;
}

.ammo-pip.empty {
    background:#333;
    opacity:0.3;
}


.reload-text{
    color:#ffd54a;
    font-weight:bold;
    font-size:14px;
    text-align:center;
    height:18px;
    opacity:0;
    transition:opacity 0.25s;
    text-shadow:0 0 6px rgba(255,213,74,0.5);
}
.reload-text.show{
    opacity:1;
}

#reload1,
#reload2{
    margin-bottom:4px;
}
@keyframes pulseReload{
    from{transform:translateY(0);}
    to{transform:translateY(-2px);}
}

#msg {
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%);
    background:rgba(0,0,0,0.9);
    padding:30px;
    color:white;
    display:none;
    border:2px solid gold;
    pointer-events:auto;
}
#countdown{
    position:absolute;
    inset:0;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:120px;
    font-weight:bold;
    color:gold;
    text-shadow:0 0 30px black;
    z-index:20;
    pointer-events:none;
    opacity:0;
    transition:opacity 0.2s;
}

#countdown.show{
    opacity:1;
}
</style>
</head>

<body>

<!-- ===== MENU ===== -->
<div id="menu">
    <h1>MEGAPIPER</h1>
    <button onclick="selectMode('pvp')">1 VS 1</button>
    <button onclick="selectMode('bot')">PLAY VS BOT</button>
</div>

<div id="difficultyMenu" style="display:none;">
    <h2>Select Difficulty</h2>
    <button onclick="startGame('easy')">EASY</button>
    <button onclick="startGame('medium')">MEDIUM</button>
    <button onclick="startGame('hard')">HARD</button>
</div>
<div id="countdown"></div>
<!-- ===== UI ===== -->
<div id="ui">
<div class="hud">

<div class="stat-box">
<div id="reload1" class="reload-text">Reloading...</div>
<div class="label"><span>BLUE</span></div>
<div class="bar-bg"><div id="p1-hp" class="bar"></div></div>
<div class="ammo-box">
<div id="p1-a1" class="ammo-pip"></div>
<div id="p1-a2" class="ammo-pip"></div>
<div id="p1-a3" class="ammo-pip"></div>
</div>
</div>

<div class="stat-box" style="text-align:right;">
<div id="reload2" class="reload-text">Reloading...</div>
<div class="label"><span>RED</span></div>
<div class="bar-bg"><div id="p2-hp" class="bar"></div></div>
<div class="ammo-box">
<div id="p2-a1" class="ammo-pip"></div>
<div id="p2-a2" class="ammo-pip"></div>
<div id="p2-a3" class="ammo-pip"></div>
</div>
</div>

</div>

<div id="msg">
<h1 id="win"></h1>
<div style="display:flex;gap:15px;justify-content:center;margin-top:20px;">
<button style="background:#00aaff;color:white;" onclick="restartGame()">PLAY AGAIN</button>
<button style="background:#ff3333;color:white;" onclick="window.location.reload()">GO TO MENU</button>
</div>
</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

<script>

/* ===== STATE ===== */
let scene,camera,renderer;
let p1,p2;
let bullets=[];

let hp1=200,hp2=200;

let ammo1=3,ammo2=3;
let reloading1=false,reloading2=false;

const MAX_AMMO=3;
const RELOAD_TIME=2000;

let mode="pvp";
let difficulty="medium";
let gameStarted=false;

let botTimer=0;
let botBrain = {
    targetX: 0,
    thinkTime: 0
};
/* ===== INPUT ===== */
const keys={
p1Left:false,p1Right:false,
p2Left:false,p2Right:false
};

/* ===== MENU ===== */
function selectMode(m){
mode=m;
document.getElementById("menu").style.display="none";

if(m==="bot"){
document.getElementById("difficultyMenu").style.display="flex";
}else{
startGame("none");
}
}

function startGame(diff){
    difficulty = diff;

    document.getElementById("difficultyMenu").style.display = "none";

    init();

    // ❌ NO comença el joc aquí
    // gameStarted = true;

    // ✅ comença el compte enrere
    startCountdown();
}

/* ===== INIT ===== */
function init(){

scene=new THREE.Scene();
scene.background=new THREE.Color(0x202030);
scene.fog=new THREE.Fog(0x202030,20,60);

camera=new THREE.PerspectiveCamera(60,innerWidth/innerHeight,0.1,1000);
camera.position.set(0,15,25);
camera.lookAt(0,0,0);

renderer=new THREE.WebGLRenderer({antialias:true});
renderer.setSize(innerWidth,innerHeight);
document.body.appendChild(renderer.domElement);

/* LIGHT */
scene.add(new THREE.AmbientLight(0x404040));
let dir=new THREE.DirectionalLight(0xffffff,0.9);
dir.position.set(10,20,10);
scene.add(dir);

/* GRID (SOFT) */
let grid=new THREE.GridHelper(60,20,0x444444,0x222222);
grid.material.transparent=true;
grid.material.opacity=0.25;
scene.add(grid);

/* GROUND */
let ground=new THREE.Mesh(
new THREE.PlaneGeometry(60,60),
new THREE.MeshPhongMaterial({color:0x111111})
);
ground.rotation.x=-Math.PI/2;
scene.add(ground);

/* PLAYERS */
p1=new THREE.Mesh(
new THREE.BoxGeometry(2,3,2),
new THREE.MeshPhongMaterial({color:0x00aaff})
);
p1.position.set(0,1.5,-10);
scene.add(p1);

p2=new THREE.Mesh(
new THREE.BoxGeometry(2,3,2),
new THREE.MeshPhongMaterial({color:0xff3333})
);
p2.position.set(0,1.5,10);
scene.add(p2);

/* INPUT */
addEventListener("keydown",down);
addEventListener("keyup",up);

animate();
}

/* ===== INPUT HOLD ===== */
function down(e){
if(e.code==="ArrowLeft") keys.p1Left=true;
if(e.code==="ArrowRight") keys.p1Right=true;
if(e.code==="ArrowUp") shoot(1);

if(mode==="pvp"){
if(e.code==="KeyA") keys.p2Left=true;
if(e.code==="KeyD") keys.p2Right=true;
if(e.code==="KeyW") shoot(2);
}
}

function up(e){
if(e.code==="ArrowLeft") keys.p1Left=false;
if(e.code==="ArrowRight") keys.p1Right=false;

if(e.code==="KeyA") keys.p2Left=false;
if(e.code==="KeyD") keys.p2Right=false;
}

/* ===== SHOOT + RELOAD ===== */
function shoot(p){
    if(!gameStarted) return;
if(p===1){
if(reloading1||ammo1<=0) return;
ammo1--;
if(ammo1===0) reload(1);
spawnBullet(p1.position,1);
}

if(p===2){
if(reloading2||ammo2<=0) return;
ammo2--;
if(ammo2===0) reload(2);
spawnBullet(p2.position,-1);
}

updateUI();
}

function reload(p){

if(p===1){
reloading1=true;
updateUI();
setTimeout(()=>{
ammo1=MAX_AMMO;
reloading1=false;
updateUI();
},RELOAD_TIME);
}

if(p===2){
reloading2=true;
updateUI();
setTimeout(()=>{
ammo2=MAX_AMMO;
reloading2=false;
updateUI();
},RELOAD_TIME);
}
}

function spawnBullet(pos,dir){
let b=new THREE.Mesh(
new THREE.SphereGeometry(0.6),
new THREE.MeshBasicMaterial({color:0xffff00})
);

b.position.copy(pos);
b.userData={dir};

scene.add(b);
bullets.push(b);
}

/* ===== BOT ===== */
function botAI(){

    if(mode !== "bot") return;

    let thinkRate;
    let moveSpeed;
    let aimError;
    let shootChance;
    let dodgeWeight;

    switch(difficulty){

case "easy":
    thinkRate = 100;     // pensa molt lent
    moveSpeed = 0.10;    // molt lent
    aimError = 10;       // s'equivoca molt
    shootChance = 0.015; // gairebé no dispara
    dodgeWeight = 4;     // quasi no esquiva
    break;

case "medium":
    thinkRate = 55;      // una mica més lent
    moveSpeed = 0.25;
    aimError = 4;
    shootChance = 0.05;
    dodgeWeight = 12;
    break;

        default: // HARD
            thinkRate = 30;
            moveSpeed = 0.6;
            aimError = 0;
            shootChance = 0.15;
            dodgeWeight = 25;
            break;
    }

    botBrain.thinkTime++;

    if(botBrain.thinkTime > thinkRate){

        let bestX = 0;
        let bestScore = -999999;

        for(let x=-14;x<=14;x++){

            let score = Math.random()*10;

            // esquivar bales
            for(let b of bullets){

                if(b.userData.dir !== 1) continue;

                let dx = Math.abs(x - b.position.x);

                score += dx * dodgeWeight;

                if(dx < 2){
                    score -= 500;
                }
            }

            // seguir el jugador
            score -= Math.abs(x - p1.position.x) * 2;

            if(score > bestScore){
                bestScore = score;
                bestX = x;
            }
        }

        // error d'apuntat segons dificultat
        bestX += (Math.random() - 0.5) * aimError;

        botBrain.targetX = bestX;
        botBrain.thinkTime = 0;
    }

    // moviment
    if(p2.position.x < botBrain.targetX){
        p2.position.x += moveSpeed;
    }

    if(p2.position.x > botBrain.targetX){
        p2.position.x -= moveSpeed;
    }

    p2.position.x =
        Math.max(-14, Math.min(14, p2.position.x));

    // dispar
    if(
        Math.abs(p2.position.x - p1.position.x) < (2 + aimError) &&
        ammo2 > 0 &&
        !reloading2
    ){
        if(Math.random() < shootChance){
            shoot(2);
        }
    }
}

/* ===== UI ===== */
function updateUI(){

for(let i=1;i<=3;i++){
document.getElementById("p1-a"+i).classList.toggle("empty",i>ammo1);
document.getElementById("p2-a"+i).classList.toggle("empty",i>ammo2);
}

document.getElementById("p1-hp").style.width=(hp1/200*100)+"%";
document.getElementById("p2-hp").style.width=(hp2/200*100)+"%";

document.getElementById("reload1").classList.toggle("show", reloading1);
document.getElementById("reload2").classList.toggle("show", reloading2);
}
function gameOver(winner){

    gameStarted = false;

    const winText = document.getElementById("win");

    if(winner === 1){
        winText.textContent = "BLUE WINS!";
        winText.style.color = "#00aaff";
    }
    else{
        winText.textContent = "RED WINS!";
        winText.style.color = "#ff3333";
    }

    winText.style.fontSize = "63px";
    winText.style.marginBottom = "25px";

    document.getElementById("msg").style.display = "block";
}


function restartGame(){

hp1=200;
hp2=200;

ammo1=3;
ammo2=3;

reloading1=false;
reloading2=false;

botTimer=0;

p1.position.set(0,1.5,-10);
p2.position.set(0,1.5,10);

for(let i=bullets.length-1;i>=0;i--){
    scene.remove(bullets[i]);
}
bullets=[];

document.getElementById("msg").style.display="none";

updateUI();

gameStarted=false;
startCountdown();}
function startCountdown(){

    const el = document.getElementById("countdown");

    let t = 3;

    el.textContent = t;
    el.classList.add("show");

    const interval = setInterval(() => {

        t--;

        if(t > 0){

            el.textContent = t;

        }
        else if(t === 0){

            el.textContent = "GO!";

        }
        else{

            clearInterval(interval);

            el.classList.remove("show");

            gameStarted = true;
        }

    }, 1000);
}

/* ===== LOOP ===== */
function animate(){

    requestAnimationFrame(animate);

    if(gameStarted){

        /* MOVE P1 */
        if(keys.p1Left && p1.position.x>-14) p1.position.x-=0.3;
        if(keys.p1Right && p1.position.x<14) p1.position.x+=0.3;

        /* MOVE P2 */
        if(mode==="pvp"){
            if(keys.p2Left && p2.position.x>-14) p2.position.x-=0.3;
            if(keys.p2Right && p2.position.x<14) p2.position.x+=0.3;
        }else{
            botAI();
        }

        /* BULLETS */
        for(let i=bullets.length-1;i>=0;i--){

            let b=bullets[i];
            b.position.z+=b.userData.dir*0.8;

            let target=b.userData.dir===1?p2:p1;

            if(
                Math.abs(b.position.x-target.position.x)<2 &&
                Math.abs(b.position.z-target.position.z)<2
            ){

                if(target===p1){

                    hp1-=20;

                    if(hp1<=0){
                        hp1=0;
                        updateUI();
                        scene.remove(b);
                        bullets.splice(i,1);
                        gameOver(2);
                        return;
                    }

                }else{

                    hp2-=20;

                    if(hp2<=0){
                        hp2=0;
                        updateUI();
                        scene.remove(b);
                        bullets.splice(i,1);
                        gameOver(1);
                        return;
                    }
                }

                scene.remove(b);
                bullets.splice(i,1);
                updateUI();
            }

            if(b.position.z>30 || b.position.z<-30){
                scene.remove(b);
                bullets.splice(i,1);
            }
        }
    }

    renderer.render(scene,camera);
}

</script>
</body>
</html>
