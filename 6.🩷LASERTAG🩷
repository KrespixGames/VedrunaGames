<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LASERTAG</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
overflow:hidden;
background:#05070a;
font-family:Arial,Helvetica,sans-serif;
}

canvas{
display:block;
background:radial-gradient(circle at center,#0f1725 0%,#05070a 75%);
}

button{
border:none;
border-radius:10px;
cursor:pointer;
font-weight:bold;
transition:0.2s;
}

button:hover{
transform:translateX(-50%) scale(1.08);
}

#playBtn{
position:absolute;
left:50%;
top:58%;
transform:translateX(-50%);
padding:14px 40px;
font-size:24px;
background:#00e5ff;
color:black;
box-shadow:0 0 20px #00e5ff;
}

#playAgain{
position:absolute;
left:50%;
top:62%;
transform:translateX(-50%);
padding:14px 40px;
font-size:24px;
background:#00ff88;
color:black;
box-shadow:0 0 20px #00ff88;
display:none;
}
</style>
</head>

<body>

<canvas id="game"></canvas>

<button id="playBtn">PLAY</button>
<button id="playAgain">PLAY AGAIN</button>

<script>

const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");

const playBtn = document.getElementById("playBtn");
const playAgainBtn = document.getElementById("playAgain");

function resize(){
canvas.width = window.innerWidth;
canvas.height = window.innerHeight;
}
resize();
window.addEventListener("resize", resize);

const keys = {};

window.addEventListener("keydown", e=>{
keys[e.key] = true;
});

window.addEventListener("keyup", e=>{
keys[e.key] = false;
});

const arena = {
x:0,
y:0,
w:0,
h:0
};

function updateArena(){
arena.w = Math.min(850, window.innerWidth - 250);
arena.h = Math.min(500, window.innerHeight - 180);
arena.x = (canvas.width - arena.w)/2;
arena.y = (canvas.height - arena.h)/2;
}

class Player{
constructor(x,y,color,controls){
this.x=x;
this.y=y;
this.size=28;
this.color=color;
this.controls=controls;
this.speed=350;
this.alive=true;
}

update(dt){
if(!this.alive) return;

let dx=0, dy=0;

if(keys[this.controls.up]) dy--;
if(keys[this.controls.down]) dy++;
if(keys[this.controls.left]) dx--;
if(keys[this.controls.right]) dx++;

if(dx||dy){
const len=Math.hypot(dx,dy);
dx/=len; dy/=len;
}

this.x+=dx*this.speed*dt;
this.y+=dy*this.speed*dt;

this.x=Math.max(arena.x,Math.min(arena.x+arena.w-this.size,this.x));
this.y=Math.max(arena.y,Math.min(arena.y+arena.h-this.size,this.y));
}

draw(){
if(!this.alive) return;

ctx.save();
ctx.shadowBlur=20;
ctx.shadowColor=this.color;
ctx.fillStyle=this.color;
ctx.fillRect(this.x,this.y,this.size,this.size);
ctx.restore();
}
}

class Laser{
constructor(){
this.x=arena.x+arena.w/2;
this.y=arena.y+arena.h/2;

this.radius=14; // FIXED SIZE FOR ALL LASERS

const angle=Math.random()*Math.PI*2;

this.speed=450;
this.vx=Math.cos(angle)*this.speed;
this.vy=Math.sin(angle)*this.speed;

this.timer=0;
this.trail=[];
}

update(dt){

// infinite acceleration
this.speed += 12*dt;

const mag=Math.hypot(this.vx,this.vy);
this.vx=(this.vx/mag)*this.speed;
this.vy=(this.vy/mag)*this.speed;

this.x+=this.vx*dt;
this.y+=this.vy*dt;

// bounce
if(this.x-this.radius<=arena.x){this.x=arena.x+this.radius;this.vx*=-1;}
if(this.x+this.radius>=arena.x+arena.w){this.x=arena.x+arena.w-this.radius;this.vx*=-1;}
if(this.y-this.radius<=arena.y){this.y=arena.y+this.radius;this.vy*=-1;}
if(this.y+this.radius>=arena.y+arena.h){this.y=arena.y+arena.h-this.radius;this.vy*=-1;}

// trail
this.trail.push({x:this.x,y:this.y,life:1});
if(this.trail.length>120)this.trail.shift();

for(const p of this.trail)p.life-=dt*2;
this.trail=this.trail.filter(p=>p.life>0);
}

draw(){
for(const p of this.trail){
ctx.beginPath();
ctx.fillStyle=`rgba(0,255,150,${p.life*0.35})`;
ctx.arc(p.x,p.y,this.radius*(0.2+p.life*0.8),0,Math.PI*2);
ctx.fill();
}

ctx.save();
ctx.shadowBlur=45;
ctx.shadowColor="#00ff88";
ctx.fillStyle="#00ff88";
ctx.beginPath();
ctx.arc(this.x,this.y,this.radius,0,Math.PI*2);
ctx.fill();
ctx.restore();
}
}

let player1, player2;
let lasers=[];
let laserSpawnTimer=0;

let state="start";
let winnerText="";
let winnerColor="white";

function resetGame(){

updateArena();

player1=new Player(arena.x+60,arena.y+arena.h/2-14,"#33aaff",
{up:"w",down:"s",left:"a",right:"d"});

player2=new Player(arena.x+arena.w-90,arena.y+arena.h/2-14,"#ff4d5c",
{up:"ArrowUp",down:"ArrowDown",left:"ArrowLeft",right:"ArrowRight"});

lasers=[new Laser()];
laserSpawnTimer=0;

winnerText="";
winnerColor="white";

playBtn.style.display="none";
playAgainBtn.style.display="none";

state="running";
}

function startGame(){resetGame();}

playBtn.addEventListener("click",startGame);
playAgainBtn.addEventListener("click",resetGame);

function hit(player){
for(const l of lasers){
const cx=Math.max(player.x,Math.min(l.x,player.x+player.size));
const cy=Math.max(player.y,Math.min(l.y,player.y+player.size));
const dx=l.x-cx, dy=l.y-cy;
if(dx*dx+dy*dy<=l.radius*l.radius)return true;
}
return false;
}

function update(dt){

if(state!=="running")return;

player1.update(dt);
player2.update(dt);

// spawn lasers every 30 seconds
laserSpawnTimer += dt;

if(laserSpawnTimer >= 30){
laserSpawnTimer = 0;
lasers.push(new Laser());
}

for(const l of lasers) l.update(dt);

// collisions
if(hit(player1)){
winnerText="PLAYER 2 WINS";
winnerColor="#ff4d5c";
state="gameover";
playAgainBtn.style.display="block";
}

if(hit(player2)){
winnerText="PLAYER 1 WINS";
winnerColor="#33aaff";
state="gameover";
playAgainBtn.style.display="block";
}
}

function drawArena(){
ctx.save();
ctx.strokeStyle="#00e5ff";
ctx.lineWidth=3;
ctx.shadowBlur=20;
ctx.shadowColor="#00e5ff";
ctx.strokeRect(arena.x,arena.y,arena.w,arena.h);
ctx.restore();
}

function render(){

ctx.clearRect(0,0,canvas.width,canvas.height);

if(state==="start"){
ctx.textAlign="center";
ctx.fillStyle="white";
ctx.font="bold 64px Arial";
ctx.fillText("LASERTAG",canvas.width/2,canvas.height/2-50);
ctx.font="24px Arial";
ctx.fillText("LOCAL 2 PLAYER LASER DUEL",canvas.width/2,canvas.height/2);
return;
}

drawArena();

for(const l of lasers)l.draw();

player1.draw();
player2.draw();

ctx.textAlign="left";
ctx.fillStyle="white";
ctx.font="18px Arial";
ctx.fillText("P1: WASD",20,35);
ctx.fillText("P2: ARROWS",20,60);
ctx.fillText("LASERS: "+lasers.length,20,85);

if(state==="gameover"){
ctx.fillStyle="rgba(0,0,0,0.6)";
ctx.fillRect(0,0,canvas.width,canvas.height);

ctx.textAlign="center";
ctx.save();
ctx.shadowBlur=40;
ctx.shadowColor=winnerColor;
ctx.fillStyle=winnerColor;
ctx.font="bold 70px Arial";
ctx.fillText(winnerText,canvas.width/2,canvas.height/2);
ctx.restore();
}
}

let last=performance.now();
function loop(now){
const dt=Math.min((now-last)/1000,0.033);
last=now;
update(dt);
render();
requestAnimationFrame(loop);
}
requestAnimationFrame(loop);

</script>
</body>
</html>
