<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Rising Lava</title>
<style>
html,body{
margin:0;padding:0;overflow:hidden;background:#05070d;
font-family:Arial,Helvetica,sans-serif;height:100%;
}
canvas{display:block;width:100vw;height:100vh;}
.overlay{
position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
background:radial-gradient(circle at center,#182235,#05070d);
color:white;flex-direction:column;z-index:10;text-align:center;
}
.hidden{display:none}
h1{
font-size:min(8vw,72px);
margin:0 0 20px;
letter-spacing:4px;
text-shadow:0 0 25px orange;
}
button{
padding:14px 28px;
margin:8px;
border:none;
border-radius:12px;
font-size:18px;
cursor:pointer;
background:#1f6fff;
color:white;
box-shadow:0 0 15px rgba(31,111,255,.6);
}
button:hover{transform:scale(1.04)}
.info{max-width:800px;padding:20px;line-height:1.5}
</style>
</head>
<body>

<canvas id="game"></canvas>

<div id="menu" class="overlay">
<h1>RISING LAVA</h1>
<button id="playBtn">Play</button>
<button id="resetBtn">Reset records</button>
<div class="info">
<p><b>Player 1</b>: A D W</p>
<p><b>Player 2</b>: ← → ↑</p>
<p>The lava keeps rising. Jump from platform to platform and be the last player alive.</p>
</div>
</div>

<div id="gameOver" class="overlay hidden">
<h1 id="winnerText">Winner</h1>
<div id="stats"></div>
<button id="againBtn">Play again</button>
</div>

<script>
const canvas=document.getElementById("game");
const ctx=canvas.getContext("2d");

let W,H;
function resize(){
W=canvas.width=innerWidth;
H=canvas.height=innerHeight;
}
addEventListener("resize",resize);
resize();

const keys={};
addEventListener("keydown",e=>keys[e.key.toLowerCase()]=true);
addEventListener("keyup",e=>keys[e.key.toLowerCase()]=false);

let audioCtx=null;
function beep(freq,dur,type="sine",vol=.04){
if(!audioCtx) audioCtx=new (window.AudioContext||window.webkitAudioContext)();
const o=audioCtx.createOscillator();
const g=audioCtx.createGain();
o.type=type;o.frequency.value=freq;
g.gain.value=vol;
o.connect(g);g.connect(audioCtx.destination);
o.start();
g.gain.exponentialRampToValueAtTime(.0001,audioCtx.currentTime+dur);
o.stop(audioCtx.currentTime+dur);
}

class Particle{
constructor(x,y,vx,vy,c,l){
this.x=x;this.y=y;this.vx=vx;this.vy=vy;
this.c=c;this.life=l;this.max=l;
}
update(dt){
this.life-=dt;
this.x+=this.vx*dt;
this.y+=this.vy*dt;
this.vy+=400*dt;
}
draw(camY){
ctx.globalAlpha=Math.max(0,this.life/this.max);
ctx.fillStyle=this.c;
ctx.beginPath();
ctx.arc(this.x,this.y-camY,3,0,Math.PI*2);
ctx.fill();
ctx.globalAlpha=1;
}
}

class Player{
constructor(x,color,controls){
this.x=x;
this.y=0;
this.w=34;
this.h=46;
this.vx=0;
this.vy=0;
this.color=color;
this.controls=controls;
this.alive=true;
this.onGround=false;
}
update(dt){
if(!this.alive)return;

const accel=1200;
const maxSpeed=300;
const friction=.88;

if(keys[this.controls.left]) this.vx-=accel*dt;
if(keys[this.controls.right]) this.vx+=accel*dt;

this.vx*=friction;
this.vx=Math.max(-maxSpeed,Math.min(maxSpeed,this.vx));

if(keys[this.controls.jump]&&this.onGround){
this.vy=-650;
this.onGround=false;
jumpParticles(this.x,this.y+this.h);
beep(600,.08,"triangle");
}

this.vy+=1400*dt;

let oldY=this.y;
this.x+=this.vx*dt;
this.y+=this.vy*dt;

if(this.x<0){this.x=0;this.vx=0;}
if(this.x+this.w>worldWidth){this.x=worldWidth-this.w;this.vx=0;}

this.onGround=false;

for(const p of platforms){
if(p.dead)continue;

let px=p.x+p.offset;
if(
this.x+this.w>px &&
this.x<px+p.w &&
oldY+this.h<=p.y &&
this.y+this.h>=p.y
){
this.y=p.y-this.h;
this.vy=0;
this.onGround=true;

if(p.type==="fragile"){
p.timer=.6;
}
if(p.type==="boost"){
this.vy=-950;
}
}
}

if(this.y>lavaY+300){
killPlayer(this);
}
}
draw(camY){
if(!this.alive)return;
ctx.save();
ctx.shadowBlur=20;
ctx.shadowColor=this.color;
ctx.fillStyle=this.color;
ctx.fillRect(this.x,this.y-camY,this.w,this.h);
ctx.restore();
}
}

const worldWidth=1200;

let players=[];
let platforms=[];
let particles=[];

let lavaY=0;
let lavaSpeed=45;
let cameraY=0;
let gameState="menu";
let startTime=0;
let maxGeneratedY=0;

function createPlatform(x,y,w,type){
return{
x,y,w,h:18,type,
offset:0,
dir:Math.random()<.5?-1:1,
timer:0,
dead:false
};
}

function generateInitial(){
platforms.length=0;
players.length=0;
particles.length=0;

let y=H-120;
platforms.push(createPlatform(450,y,220,"normal"));

for(let i=0;i<40;i++){
y-=110;
addGeneratedPlatform(y);
}

maxGeneratedY=y;

players.push(new Player(500,"#3da0ff",{left:"a",right:"d",jump:"w"}));
players.push(new Player(620,"#ff4b4b",{left:"arrowleft",right:"arrowright",jump:"arrowup"}));

players[0].y=H-200;
players[1].y=H-200;

lavaY=H+150;
lavaSpeed=45;
cameraY=0;
startTime=performance.now();
}

function addGeneratedPlatform(y){
const last=platforms[platforms.length-1];
let prevX=last?last.x:500;

let jumpRange=220;
let nx=Math.max(40,Math.min(worldWidth-260,prevX+(Math.random()*2-1)*jumpRange));

let typeRand=Math.random();
let type="normal";
if(typeRand>.65&&typeRand<.8) type="mobile";
else if(typeRand>=.8&&typeRand<.92) type="fragile";
else if(typeRand>=.92) type="boost";

platforms.push(
createPlatform(
nx,
y,
120+Math.random()*140,
type
)
);
}

function jumpParticles(x,y){
for(let i=0;i<10;i++){
particles.push(new Particle(
x+Math.random()*30,
y,
(Math.random()-.5)*180,
-Math.random()*180,
"#ffffff",
.6
));
}
}

function deathParticles(x,y,color){
for(let i=0;i<40;i++){
particles.push(new Particle(
x,y,
(Math.random()-.5)*500,
(Math.random()-.5)*500,
color,
1.2
));
}
}

function killPlayer(p){
if(!p.alive)return;
p.alive=false;
deathParticles(p.x,p.y,p.color);
beep(120,.4,"sawtooth",.06);

const alive=players.filter(a=>a.alive);
if(alive.length<=1){
finishGame(alive[0]);
}
}

function finishGame(winner){
gameState="over";

let time=((performance.now()-startTime)/1000).toFixed(1);
let record=Math.max(+localStorage.getItem("lavaRecord")||0,+time);
localStorage.setItem("lavaRecord",record);

document.getElementById("winnerText").textContent=
winner?`Player ${winner.color==="#3da0ff"?"1":"2"} wins!`:"Draw";

document.getElementById("stats").innerHTML=
`Time: ${time}s<br>Record: ${record.toFixed(1)}s`;

document.getElementById("gameOver").classList.remove("hidden");

beep(900,.2);
setTimeout(()=>beep(1200,.25),150);
}

function startGame(){
document.getElementById("menu").classList.add("hidden");
document.getElementById("gameOver").classList.add("hidden");
generateInitial();
gameState="playing";
}

document.getElementById("playBtn").onclick=()=>{beep(700,.08);startGame();};
document.getElementById("againBtn").onclick=()=>{beep(700,.08);startGame();};
document.getElementById("resetBtn").onclick=()=>{localStorage.removeItem("lavaRecord");beep(300,.1);};

let last=0;

function update(dt){
if(gameState!=="playing") return;

lavaSpeed+=dt*1.2;
lavaY-=lavaSpeed*dt;

const alivePlayers=players.filter(p=>p.alive);

if(alivePlayers.length){
const target=Math.min(...alivePlayers.map(p=>p.y))-H*.45;
cameraY+=(target-cameraY)*0.06;
}

for(const p of players){
p.update(dt);
if(p.alive && p.y+p.h>lavaY) killPlayer(p);
}

for(const pl of platforms){
if(pl.type==="mobile"){
pl.offset+=pl.dir*100*dt;
if(pl.offset>140||pl.offset<-140) pl.dir*=-1;
}
if(pl.type==="fragile" && pl.timer>0){
pl.timer-=dt;
if(pl.timer<=0) pl.dead=true;
}
}

while(maxGeneratedY>cameraY-2500){
maxGeneratedY-=100+Math.random()*30;
addGeneratedPlatform(maxGeneratedY);
}

platforms=platforms.filter(p=>p.y<cameraY+H+600 && !((p.dead)&&p.y>cameraY+H));

for(let i=particles.length-1;i>=0;i--){
particles[i].update(dt);
if(particles[i].life<=0) particles.splice(i,1);
}

for(let i=0;i<4;i++){
particles.push(new Particle(
Math.random()*worldWidth,
lavaY,
(Math.random()-.5)*40,
-40-Math.random()*120,
"orange",
1
));
}
}

function drawBackground(){
let g=ctx.createLinearGradient(0,0,0,H);
g.addColorStop(0,"#10192e");
g.addColorStop(1,"#040507");
ctx.fillStyle=g;
ctx.fillRect(0,0,W,H);
}

function drawPlatforms(){
for(const p of platforms){
if(p.dead) continue;

let x=p.x+p.offset;
let y=p.y-cameraY;

ctx.save();

if(p.type==="normal") ctx.fillStyle="#7be0ff";
if(p.type==="mobile") ctx.fillStyle="#b16dff";
if(p.type==="fragile") ctx.fillStyle="#ffd36d";
if(p.type==="boost") ctx.fillStyle="#6dff8d";

ctx.shadowBlur=15;
ctx.shadowColor=ctx.fillStyle;
ctx.fillRect(x,y,p.w,p.h);

ctx.restore();
}
}

function drawLava(){
const y=lavaY-cameraY;

let g=ctx.createLinearGradient(0,y,0,H);
g.addColorStop(0,"#ffef66");
g.addColorStop(.2,"#ff6a00");
g.addColorStop(1,"#a00000");

ctx.fillStyle=g;
ctx.shadowBlur=30;
ctx.shadowColor="orange";

ctx.fillRect(0,y,W,H-y);

ctx.beginPath();
for(let x=0;x<W;x+=20){
ctx.lineTo(x,y+Math.sin((x+performance.now()*0.01)*0.05)*8);
}
ctx.strokeStyle="#fff4a3";
ctx.lineWidth=3;
ctx.stroke();
}

function drawHUD(){
ctx.fillStyle="white";
ctx.font="18px Arial";

let time=((performance.now()-startTime)/1000).toFixed(1);
let alive=players.filter(p=>p.alive).length;
let highest=Math.max(...players.map(p=>-p.y));
highest=Math.max(0,highest|0);

ctx.fillText("Time: "+time+"s",20,30);
ctx.fillText("Lava speed: "+lavaSpeed.toFixed(1),20,55);
ctx.fillText("Alive players: "+alive,20,80);
}

function render(){
ctx.save();

let scale=W/worldWidth;
let worldScreenWidth=worldWidth*scale;
let offsetX=(W-worldScreenWidth)/2;

ctx.translate(offsetX,0);
ctx.scale(scale,1);

drawBackground();
drawPlatforms();

for(const p of players) p.draw(cameraY);

for(const part of particles) part.draw(cameraY);

drawLava();

ctx.restore();

if(gameState==="playing") drawHUD();
}

function loop(t){
let dt=(t-last)/1000;
last=t;
dt=Math.min(dt,.033);

update(dt);
render();

requestAnimationFrame(loop);
}
requestAnimationFrame(loop);
</script>
</body>
</html>
