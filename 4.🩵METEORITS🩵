<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Meteor Dodge Arena</title>

<style>
html, body {
    margin: 0;
    height: 100%;
    overflow: hidden;
    background: #000;
    font-family: Arial, sans-serif;
}

canvas {
    display: block;
}

/* MENU */
#menu {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.9);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
}

#menu h1 {
    font-size: 60px;
    margin: 0;
}

#menu p {
    color: #aaa;
    margin-top: 10px;
}

#startBtn, #soloBtn {
    margin-top: 15px;
    padding: 15px 30px;
    font-size: 22px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: bold;
}

#startBtn {
    background: linear-gradient(90deg, #33aaff, #ff3333);
    color: white;
}

#soloBtn {
    background: #444;
    color: white;
}

/* SOLO SELECT */
#soloSelect {
    position: absolute;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, #111, #000);
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
}

#soloSelect h2 {
    font-size: 42px;
    margin-bottom: 25px;
    letter-spacing: 2px;
}

#bluePick, #redPick {
    margin: 12px;
    padding: 18px 35px;
    font-size: 22px;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    font-weight: bold;
    transition: 0.2s;
}

#bluePick {
    background: #33aaff;
    color: #000;
    box-shadow: 0 0 20px #33aaff;
}

#redPick {
    background: #ff3333;
    color: #000;
    box-shadow: 0 0 20px #ff3333;
}

#bluePick:hover, #redPick:hover {
    transform: scale(1.08);
}

/* GAME OVER */
#playAgain, #menuBtn {
    position: absolute;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 15px 30px;
    font-size: 22px;
    font-weight: bold;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    background: #fff;
    color: #000;
    display: none;
}

#playAgain { top: 45%; }
#menuBtn { top: 60%; }
</style>
</head>

<body>

<!-- MENU -->
<div id="menu">
    <h1>METEOR DODGE</h1>
    <p>Blue: W A S D · Red: Arrow Keys</p>
    <button id="startBtn">PLAY</button>
    <button id="soloBtn">PLAY SOLO</button>
</div>

<!-- SOLO SELECT -->
<div id="soloSelect">
    <h2>WHICH PLAYER DO YOU WANT?</h2>
    <button id="bluePick">BLUE PLAYER</button>
    <button id="redPick">RED PLAYER</button>
</div>

<canvas id="c"></canvas>

<button id="playAgain">PLAY AGAIN</button>
<button id="menuBtn">GO TO MENU</button>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

const menu = document.getElementById("menu");
const soloSelect = document.getElementById("soloSelect");

const startBtn = document.getElementById("startBtn");
const soloBtn = document.getElementById("soloBtn");

const bluePick = document.getElementById("bluePick");
const redPick = document.getElementById("redPick");

const playAgainBtn = document.getElementById("playAgain");
const menuBtn = document.getElementById("menuBtn");

function resize() {
    canvas.width = innerWidth;
    canvas.height = innerHeight;
}
addEventListener("resize", resize);
resize();

const keys = {};
onkeydown = e => keys[e.key.toLowerCase()] = true;
onkeyup = e => keys[e.key.toLowerCase()] = false;

let p1, p2, meteors;
let gameOver = false;
let running = false;

let soloMode = false;
let soloPlayer = "blue";

function initGame() {
    p1 = { x: 200, y: 400, c: "#33aaff", dead: false };
    p2 = { x: 600, y: 400, c: "#ff3333", dead: false };

    meteors = [];
    gameOver = false;
    running = true;

    playAgainBtn.style.display = "none";
    menuBtn.style.display = "none";
}

function ship(p) {
    ctx.save();
    ctx.translate(p.x, p.y);

    ctx.fillStyle = p.c;
    ctx.beginPath();
    ctx.moveTo(0, -25);
    ctx.lineTo(18, 20);
    ctx.lineTo(0, 10);
    ctx.lineTo(-18, 20);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
}

function meteor() {
    meteors.push({
        x: Math.random() * canvas.width,
        y: -30,
        r: 15 + Math.random() * 25,
        s: soloMode
            ? (6 + Math.random() * 8)   // 💥 2x speed SOLO
            : (3 + Math.random() * 4)
    });
}

setInterval(() => {
    if (running && !gameOver) meteor();
}, 500);

function hit(p, m) {
    return Math.hypot(p.x - m.x, p.y - m.y) < m.r + 20;
}

function showGameOverButtons() {
    playAgainBtn.style.display = "block";
    menuBtn.style.display = "block";
}

/* MENU BUTTONS */
startBtn.onclick = () => {
    soloMode = false;
    menu.style.display = "none";
    initGame();
};

soloBtn.onclick = () => {
    menu.style.display = "none";
    soloSelect.style.display = "flex";
};

bluePick.onclick = () => {
    soloMode = true;
    soloPlayer = "blue";
    soloSelect.style.display = "none";
    initGame();
};

redPick.onclick = () => {
    soloMode = true;
    soloPlayer = "red";
    soloSelect.style.display = "none";
    initGame();
};

playAgainBtn.onclick = () => {
    initGame();
};

menuBtn.onclick = () => {
    running = false;
    gameOver = false;

    menu.style.display = "flex";
    soloSelect.style.display = "none";
    playAgainBtn.style.display = "none";
    menuBtn.style.display = "none";
};

function loop() {
    requestAnimationFrame(loop);

    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    if (running && !gameOver) {

        /* MOVEMENT */
        if (!soloMode || soloPlayer === "blue") {
            if (keys.w) p1.y -= 6;
            if (keys.s) p1.y += 6;
            if (keys.a) p1.x -= 6;
            if (keys.d) p1.x += 6;
        }

        if (!soloMode || soloPlayer === "red") {
            if (keys.arrowup) p2.y -= 6;
            if (keys.arrowdown) p2.y += 6;
            if (keys.arrowleft) p2.x -= 6;
            if (keys.arrowright) p2.x += 6;
        }

        meteors.forEach(m => {
            m.y += m.s;

            if (!soloMode) {
                if (!p1.dead && hit(p1, m)) {
                    p1.dead = true;
                    gameOver = true;
                    showGameOverButtons();
                }

                if (!p2.dead && hit(p2, m)) {
                    p2.dead = true;
                    gameOver = true;
                    showGameOverButtons();
                }
            } else {
                if (soloPlayer === "blue" && !p1.dead && hit(p1, m)) {
                    p1.dead = true;
                    gameOver = true;
                    showGameOverButtons();
                }

                if (soloPlayer === "red" && !p2.dead && hit(p2, m)) {
                    p2.dead = true;
                    gameOver = true;
                    showGameOverButtons();
                }
            }
        });
    }

    meteors.forEach(m => {
        ctx.fillStyle = "#888";
        ctx.beginPath();
        ctx.arc(m.x, m.y, m.r, 0, Math.PI * 2);
        ctx.fill();
    });

    if (soloMode) {
        if (soloPlayer === "blue") ship(p1);
        else ship(p2);
    } else {
        ship(p1);
        ship(p2);
    }

    if (gameOver) {
        ctx.fillStyle = "#fff";
        ctx.font = "50px Arial";
        ctx.textAlign = "center";
        ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2);
    }
}

loop();
</script>

</body>
</html>
