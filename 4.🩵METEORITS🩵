<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Meteor Dodge Arena</title>
<style>
html, body {
    margin: 0;
    height: 100%;
    overflow: hidden;
    background: #000;
    font-family: Arial, sans-serif;
}

canvas {
    display: block;
}

#playAgain {
    position: absolute;
    left: 50%;
    top: 60%;
    transform: translate(-50%, -50%);
    padding: 15px 30px;
    font-size: 22px;
    font-weight: bold;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    background: #fff;
    color: #000;
    display: none;
}
</style>
</head>
<body>

<canvas id="c"></canvas>
<button id="playAgain">PLAY AGAIN</button>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");
const playAgainBtn = document.getElementById("playAgain");

function resize() {
    canvas.width = innerWidth;
    canvas.height = innerHeight;
}
addEventListener("resize", resize);
resize();

const keys = {};
onkeydown = e => keys[e.key.toLowerCase()] = true;
onkeyup = e => keys[e.key.toLowerCase()] = false;

let p1, p2, meteors, gameOver, winnerText, winnerColor;

function initGame() {
    p1 = { x: 200, y: 400, c: "#33aaff", dead: false };
    p2 = { x: 600, y: 400, c: "#ff3333", dead: false };

    meteors = [];
    gameOver = false;

    winnerText = "";
    winnerColor = "#fff";

    playAgainBtn.style.display = "none";
}

function ship(p) {
    ctx.save();
    ctx.translate(p.x, p.y);

    ctx.fillStyle = p.c;
    ctx.beginPath();
    ctx.moveTo(0, -25);
    ctx.lineTo(18, 20);
    ctx.lineTo(0, 10);
    ctx.lineTo(-18, 20);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
}

function meteor() {
    meteors.push({
        x: Math.random() * canvas.width,
        y: -30,
        r: 15 + Math.random() * 25,
        s: 3 + Math.random() * 4
    });
}

setInterval(() => {
    if (!gameOver) meteor();
}, 500);

function hit(p, m) {
    return Math.hypot(p.x - m.x, p.y - m.y) < m.r + 20;
}

playAgainBtn.onclick = initGame;

// 🎨 COLORED INSTRUCTIONS
function drawInstructions() {
    ctx.font = "18px Arial";
    ctx.textAlign = "left";



    // Blue controls
    ctx.fillStyle = "#33aaff";
    ctx.fillText("BLUE: W, A, S, D", 20, 50);

    // Red controls
    ctx.fillStyle = "#ff3333";
    ctx.fillText("RED: O, K, L, Ñ", 20, 75);


}

function loop() {
    requestAnimationFrame(loop);

    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    if (!gameOver) {

        if (keys.w) p1.y -= 6;
        if (keys.s) p1.y += 6;
        if (keys.a) p1.x -= 6;
        if (keys.d) p1.x += 6;

        if (keys.o) p2.y -= 6;
        if (keys.l) p2.y += 6;
        if (keys.k) p2.x -= 6;
        if (keys.ñ) p2.x += 6;

        meteors.forEach(m => {
            m.y += m.s;

            if (!p1.dead && hit(p1, m)) {
                p1.dead = true;
                gameOver = true;
                winnerText = "RED WINS!";
                winnerColor = p2.c;
                playAgainBtn.style.display = "block";
            }

            if (!p2.dead && hit(p2, m)) {
                p2.dead = true;
                gameOver = true;
                winnerText = "BLUE WINS!";
                winnerColor = p1.c;
                playAgainBtn.style.display = "block";
            }
        });
    }

    meteors.forEach(m => {
        ctx.fillStyle = "#888";
        ctx.beginPath();
        ctx.arc(m.x, m.y, m.r, 0, Math.PI * 2);
        ctx.fill();
    });

    if (!p1.dead) ship(p1);
    if (!p2.dead) ship(p2);

    drawInstructions();

    if (gameOver) {
        ctx.fillStyle = winnerColor;
        ctx.font = "50px Arial";
        ctx.textAlign = "center";
        ctx.fillText(winnerText, canvas.width / 2, canvas.height / 2);
    }
}

initGame();
loop();
</script>

</body>
</html>
