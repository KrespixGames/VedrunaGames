<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Meteor Dodge Arena</title>

<style>
html, body {
    margin: 0;
    height: 100%;
    overflow: hidden;
    background: #000;
    font-family: Arial, sans-serif;
}

canvas {
    display: block;
}

/* BUTTONS */
#playAgain, #menuBtn {
    position: absolute;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 15px 30px;
    font-size: 22px;
    font-weight: bold;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    background: #fff;
    color: #000;
    display: none;
}

#menuBtn {
    top: 55%;
}

/* MENU */
#menu {
    position: absolute;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.9);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    color: white;
    text-align: center;
}

#menu h1 {
    font-size: 60px;
    margin: 0;
}

#menu p {
    color: #aaa;
    margin-top: 10px;
}

#startBtn {
    margin-top: 30px;
    padding: 15px 30px;
    font-size: 22px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    background: linear-gradient(90deg, #33aaff, #ff3333);
    color: white;
    font-weight: bold;
}

</style>
</head>

<body>

<!-- MENU -->
<div id="menu">
    <h1>METEOR DODGE</h1>
    <p>Blue: W A S D · Red: Arrow Keys</p>
    <button id="startBtn">PLAY</button>
</div>

<canvas id="c"></canvas>
<button id="playAgain">PLAY AGAIN</button>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

const playAgainBtn = document.getElementById("playAgain");
const menu = document.getElementById("menu");
const startBtn = document.getElementById("startBtn");

function resize() {
    canvas.width = innerWidth;
    canvas.height = innerHeight;
}
addEventListener("resize", resize);
resize();

const keys = {};
onkeydown = e => keys[e.key.toLowerCase()] = true;
onkeyup = e => keys[e.key.toLowerCase()] = false;

let p1, p2, meteors, gameOver, running;

function initGame() {
    p1 = { x: 200, y: 400, c: "#33aaff", dead: false };
    p2 = { x: 600, y: 400, c: "#ff3333", dead: false };

    meteors = [];
    gameOver = false;
    running = true;

    playAgainBtn.style.display = "none";
}

function ship(p) {
    ctx.save();
    ctx.translate(p.x, p.y);

    ctx.fillStyle = p.c;
    ctx.beginPath();
    ctx.moveTo(0, -25);
    ctx.lineTo(18, 20);
    ctx.lineTo(0, 10);
    ctx.lineTo(-18, 20);
    ctx.closePath();
    ctx.fill();

    ctx.restore();
}

function meteor() {
    meteors.push({
        x: Math.random() * canvas.width,
        y: -30,
        r: 15 + Math.random() * 25,
        s: 3 + Math.random() * 4
    });
}

setInterval(() => {
    if (running && !gameOver) meteor();
}, 500);

function hit(p, m) {
    return Math.hypot(p.x - m.x, p.y - m.y) < m.r + 20;
}

playAgainBtn.onclick = () => {
    initGame();
};

startBtn.onclick = () => {
    menu.style.display = "none";
    initGame();
};

function drawInstructions() {
    ctx.font = "18px Arial";
    ctx.textAlign = "left";

    ctx.fillStyle = "#33aaff";
    ctx.fillText("BLUE: W, A, S, D", 20, 50);

    ctx.fillStyle = "#ff3333";
    ctx.fillText("RED: ARROWS", 20, 75);
}

function loop() {
    requestAnimationFrame(loop);

    ctx.fillStyle = "#000";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    if (running && !gameOver) {

        // BLUE
        if (keys.w) p1.y -= 6;
        if (keys.s) p1.y += 6;
        if (keys.a) p1.x -= 6;
        if (keys.d) p1.x += 6;

        // RED (ARROWS)
        if (keys.arrowup) p2.y -= 6;
        if (keys.arrowdown) p2.y += 6;
        if (keys.arrowleft) p2.x -= 6;
        if (keys.arrowright) p2.x += 6;

        meteors.forEach(m => {
            m.y += m.s;

            if (!p1.dead && hit(p1, m)) {
                p1.dead = true;
                gameOver = true;
                playAgainBtn.style.display = "block";
            }

            if (!p2.dead && hit(p2, m)) {
                p2.dead = true;
                gameOver = true;
                playAgainBtn.style.display = "block";
            }
        });
    }

    meteors.forEach(m => {
        ctx.fillStyle = "#888";
        ctx.beginPath();
        ctx.arc(m.x, m.y, m.r, 0, Math.PI * 2);
        ctx.fill();
    });

    if (!p1.dead) ship(p1);
    if (!p2.dead) ship(p2);

    drawInstructions();

    if (gameOver) {
        ctx.fillStyle = "#fff";
        ctx.font = "50px Arial";
        ctx.textAlign = "center";
        ctx.fillText("GAME OVER", canvas.width / 2, canvas.height / 2);
    }
}

loop();
</script>

</body>
</html>
